# Argus — Environment Variables Reference
#
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# All data-source config can also be set in config/settings.local.yaml.
# Environment variables take precedence over settings.yaml.

# ── Satellite data (CDSE) ────────────────────────────────────────────────────
# Required for live Sentinel-1/2/3 imagery downloads.
# Register for free at https://dataspace.copernicus.eu/
ARGUS_CDSE_USER=your_email@example.com
ARGUS_CDSE_PASSWORD=your_cdse_password

# ── Marine data (CMEMS) ──────────────────────────────────────────────────────
# Required for ocean-current forcing in oil trajectory simulations.
# Register for free at https://marine.copernicus.eu/
ARGUS_CMEMS_USER=your_email@example.com
ARGUS_CMEMS_PASSWORD=your_cmems_password

# ── AI assistant ─────────────────────────────────────────────────────────────
# Required for live NL reports and NL query.
# Obtain from https://console.anthropic.com/
# The Anthropic SDK reads this variable automatically.
ANTHROPIC_API_KEY=sk-ant-...

# Set to "true" to skip all LLM calls and use deterministic template fallback.
# Recommended for local development unless you are working on the AI layer.
ARGUS_AI_OFFLINE=true

# ── Database ─────────────────────────────────────────────────────────────────
# Override the SQLite database path (default: data/argus.db)
# ARGUS_STORE_DB_PATH=data/argus.db

# ── Alerting (optional) ───────────────────────────────────────────────────────
# Webhook URL for alert delivery (leave blank to disable)
# ARGUS_ALERTS_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Logging ──────────────────────────────────────────────────────────────────
# "json" for structured production logs; "text" for human-readable dev logs
# ARGUS_LOGGING_FORMAT=text
# ARGUS_LOGGING_LEVEL=INFO

# ── Profile ───────────────────────────────────────────────────────────────────
# Set to load config/settings.<profile>.yaml on top of the base settings.
# ARGUS_PROFILE=dev
